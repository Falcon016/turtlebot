# Model routing
MODEL_PROVIDER=ollama
MODEL=qwen3:4b
THINK_MODEL=lfm2.5-thinking

# OpenAI mode (only if MODEL_PROVIDER=openai)
OPENAI_API_KEY=

# Ollama mode
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional Telegram bot mode
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLL_INTERVAL_MS=2500

# Runtime
WORKSPACE_DIR=./workspace
LOG_LEVEL=info
MAX_HISTORY=12

# Tool safety
ALLOW_EXEC=true
EXEC_POLICY=allowlist
EXEC_ALLOWLIST=ls,cat,echo,pwd,git status,git log
EXEC_CONFIRM_TOKEN=

# Ollama reliability
OLLAMA_TIMEOUT_MS=45000
OLLAMA_RETRIES=1
